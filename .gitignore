# =============================================================================
# AEL AGENT PROJECT — .gitignore
# =============================================================================
# This file ensures no secrets, build output, or developer-specific junk
# is ever pushed to the shared repository.
# =============================================================================

# -----------------------------------------------------------------------------
# 1. SECRETS & ENVIRONMENT VARIABLES
#    Never commit .env files — all keys live in .env.local on each developer's
#    machine. The .env.local.example file is safe and intentionally included.
# -----------------------------------------------------------------------------
.env
.env.*
!.env.local.example

# -----------------------------------------------------------------------------
# 2. NEXT.JS BUILD OUTPUT
# -----------------------------------------------------------------------------
/.next/
/out/
/build/
.next

# -----------------------------------------------------------------------------
# 3. NODE DEPENDENCIES
#    node_modules should be reproduced from package.json via `npm install`.
# -----------------------------------------------------------------------------
/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -----------------------------------------------------------------------------
# 4. TYPESCRIPT COMPILATION CACHE
#    tsbuildinfo is a local incremental compilation cache, not source code.
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# 5. PACKAGE MANAGER LOCK FILES (keep only package-lock.json)
#    Exclude yarn and pnpm lock files to avoid conflicts.
# -----------------------------------------------------------------------------
yarn.lock
pnpm-lock.yaml

# -----------------------------------------------------------------------------
# 6. TEST & COVERAGE OUTPUT
# -----------------------------------------------------------------------------
/coverage/
*.lcov
.nyc_output/

# -----------------------------------------------------------------------------
# 7. SCRATCH / THROWAWAY SCRIPTS
#    The /scratch directory contains temporary one-off debugging scripts that
#    are not part of the production codebase.
# -----------------------------------------------------------------------------
/scratch/

# -----------------------------------------------------------------------------
# 8. LOG FILES
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# -----------------------------------------------------------------------------
# 9. OS & SYSTEM JUNK
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# 10. EDITOR & IDE CONFIGURATION
#     Each developer uses their own editor — don't commit editor preferences.
# -----------------------------------------------------------------------------
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# -----------------------------------------------------------------------------
# 11. VERCEL DEPLOYMENT METADATA
# -----------------------------------------------------------------------------
.vercel/

# -----------------------------------------------------------------------------
# 12. SSL / CERTIFICATES
# -----------------------------------------------------------------------------
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx

# -----------------------------------------------------------------------------
# 13. DEBUG & PROFILING
# -----------------------------------------------------------------------------
.clinic/
*.heapsnapshot
*.cpuprofile

# -----------------------------------------------------------------------------
# 14. MISC TEMP FILES
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.orig
.cache/
dist/

# -----------------------------------------------------------------------------
# 15. TEST & REMEDIATION SCRIPTS
#     One-off test and debug scripts at root or /scratch level.
# -----------------------------------------------------------------------------
test_*.ts
test_*.js
debug_*.ts
debug_*.js
mock_*.ts
mock_*.js
check_db.js
/scratch/

# -----------------------------------------------------------------------------
# 16. BRAIN / AGENT CONTEXT DIRECTORY
#     Contains AI agent scratch notes, state logs, and conversation artifacts.
#     Not production code — should not be committed.
# -----------------------------------------------------------------------------
/brain/

# -----------------------------------------------------------------------------
# 17. TYPESCRIPT BUILD CACHE
#     Build info files are local incremental caches, not source code.
# -----------------------------------------------------------------------------
tsconfig.tsbuildinfo
*.tsbuildinfo
