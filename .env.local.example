# Next.js Public Keys (Copy from Supabase Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key

# Supabase Admin / Service Role Key (Bypasses Row Level Security - Keep Secret!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Supabase Postgres Connection String (Needed for the LangGraph Postgres checkpointer)
# Format: postgres://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:5432/postgres
SUPABASE_DATABASE_CONNECTION_STRING=your_postgres_connection_string

# Google Gemini API Key (Generate from https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key

# GitHub Personal Access Token (PAT) (Generate from GitHub Settings > Developer Settings)
GITHUB_PAT=your_github_personal_access_token

# Google Calendar/Meet OAuth Integration (Create in Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# Google Refresh Token (Generated once for offline backend API access)
GOOGLE_REFRESH_TOKEN=your_oauth_refresh_token_for_offline_access

# Node Environment
NODE_ENV=development

# Vercel Log Drain Secret Token (for securing live log ingestion webhook)
VERCEL_LOG_DRAIN_SECRET=your_custom_secure_secret_token
